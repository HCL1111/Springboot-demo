{
  "displayName": "Cloud Run Service Down - confluence-rag-chatbot",
  "documentation": {
    "content": "The Cloud Run service confluence-rag-chatbot is down or not receiving traffic",
    "mimeType": "text/markdown"
  },
  "conditions": [
    {
      "displayName": "Service Request Count Too Low",
      "conditionThreshold": {
        "filter": "resource.type=\"cloud_run_revision\" AND resource.labels.service_name=\"confluence-rag-chatbot\" AND metric.type=\"run.googleapis.com/request_count\"",
        "comparison": "COMPARISON_LT",
        "thresholdValue": 0.01,
        "duration": "120s",
        "aggregations": [
          {
            "alignmentPeriod": "60s",
            "perSeriesAligner": "ALIGN_RATE",
            "crossSeriesReducer": "REDUCE_SUM"
          }
        ]
      }
    }
  ],
  "notificationChannels": [
    "projects/project-f410cb7f-3020-43e6-8a9/notificationChannels/8199605340313241478"
  ],
  "combiner": "OR",
  "enabled": true
}

